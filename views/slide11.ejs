<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Slide 11 - Poderosa</title>
  <style>
    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:#eef3fb;
    }

    .slide{
      width:1600px;
      height:900px;
      position:relative;
      overflow:hidden;
      background:linear-gradient(180deg,#ffffff 0%, #f7fbff 100%);
      color:#0b235d;
      padding:24px 28px 22px 28px;
    }

    .top-curve{
      position:absolute;
      top:0;
      right:0;
      width:360px;
      height:92px;
      background:linear-gradient(135deg,#0b5fe0 0%, #0a2d8f 100%);
      border-bottom-left-radius:115px;
      z-index:0;
    }

    .bottom-band{
      position:absolute;
      bottom:0;
      left:0;
      width:100%;
      height:24px;
      background:linear-gradient(90deg,#0b2f8e 0%, #0f62e0 55%, #16b8bb 100%);
      z-index:0;
    }

    .header{
      position:relative;
      z-index:2;
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:18px;
    }

    .title-wrap{
      display:flex;
      align-items:center;
      gap:18px;
    }

    .title-bar{
      width:14px;
      height:54px;
      background:linear-gradient(180deg,#0f67e4 0%, #18c5c3 100%);
      border-radius:3px;
    }

    .title{
      font-size:34px;
      font-weight:900;
      color:#092561;
      letter-spacing:-0.5px;
      line-height:1.1;
    }

    .logo{
      position:relative;
      z-index:3;
      color:#fff;
      display:flex;
      align-items:center;
      gap:12px;
      padding-right:24px;
      font-weight:900;
      font-size:38px;
    }

    .logo-symbol{
      width:48px;
      height:28px;
      border:5px dashed rgba(255,255,255,0.9);
      border-radius:50%;
      transform:rotate(-18deg);
    }

    .kpi-row{
      position:relative;
      z-index:2;
      display:grid;
      grid-template-columns:repeat(6,1fr);
      gap:16px;
      margin-bottom:18px;
    }

    .kpi-card{
      height:116px;
      background:#fff;
      border:1px solid #d8e1ef;
      border-radius:18px;
      box-shadow:0 8px 20px rgba(11,45,92,0.12);
      display:grid;
      grid-template-columns:84px 1fr;
      align-items:center;
      gap:14px;
      padding:14px 18px;
    }

    .kpi-icon{
      width:72px;
      height:72px;
      border-radius:18px;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 18px rgba(0,0,0,0.16);
    }

    .bg-blue{ background:linear-gradient(135deg,#1267e2,#06339c); }
    .bg-teal{ background:linear-gradient(135deg,#18c5c5,#0a8a95); }
    .bg-orange{ background:linear-gradient(135deg,#ffb321,#ff6200); }
    .bg-purple{ background:linear-gradient(135deg,#9645ea,#5a22b1); }

    .kpi-label{
      color:#0d2b6f;
      font-size:14px;
      font-weight:900;
      text-transform:uppercase;
      line-height:1.15;
      margin-bottom:6px;
    }

    .kpi-value{
      font-size:42px;
      font-weight:900;
      line-height:1;
      color:#0f5adb;
    }

    .kpi-value.teal{ color:#0a9098; }
    .kpi-value.orange{ color:#ff6200; }
    .kpi-value.purple{ color:#7d34dd; }

    .main-grid{
      position:relative;
      z-index:2;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
      margin-bottom:16px;
      height:440px;
    }

    .panel{
      background:#fff;
      border:1px solid #d8e1ef;
      border-radius:18px;
      box-shadow:0 8px 20px rgba(11,45,92,0.12);
      overflow:hidden;
    }

    .panel-title{
      height:42px;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      color:#fff;
      font-size:18px;
      font-weight:900;
      text-transform:uppercase;
      background:linear-gradient(90deg,#0b2f98 0%, #0f5ad9 52%, #16b8bb 100%);
      padding:0 12px;
    }

    .chart-box{
      height:398px;
      padding:14px 18px 10px 18px;
    }

    .bottom-grid{
      position:relative;
      z-index:2;
      display:grid;
      grid-template-columns:0.57fr 0.43fr;
      gap:16px;
      height:170px;
    }

    .summary-card{
      background:#fff;
      border:1px solid #d8e1ef;
      border-radius:18px;
      box-shadow:0 8px 20px rgba(11,45,92,0.12);
      overflow:hidden;
      display:grid;
      grid-template-columns:108px 1fr;
    }

    .summary-side{
      display:flex;
      align-items:center;
      justify-content:center;
      border-right:1px solid #d8e1ef;
      background:#fff;
    }

    .summary-icon{
      width:74px;
      height:74px;
      border-radius:18px;
      background:linear-gradient(135deg,#1267e2,#06339c);
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 18px rgba(11,45,92,0.18);
    }

    .summary-main{
      display:flex;
      flex-direction:column;
    }

    .summary-title{
      height:42px;
      display:flex;
      align-items:center;
      padding:0 18px;
      color:#fff;
      font-size:18px;
      font-weight:900;
      text-transform:uppercase;
      background:linear-gradient(90deg,#0b2f98 0%, #0f5ad9 100%);
    }

    table{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
    }

    th{
      background:#0d54c4;
      color:#fff;
      border:1px solid #d7e0ee;
      height:31px;
      font-size:15px;
      font-weight:900;
      text-transform:uppercase;
      text-align:center;
    }

    td{
      border:1px solid #d7e0ee;
      height:31px;
      font-size:15px;
      color:#08245c;
      text-align:center;
      background:#ffffff;
    }

    .total-row td{
      background:linear-gradient(90deg,#0ab08f 0%, #13b8bb 100%);
      color:#ffffff;
      font-weight:900;
    }

    .insight-box{
      background:#fff;
      border:2px solid #18b4b7;
      border-radius:18px;
      box-shadow:0 8px 20px rgba(11,45,92,0.10);
      display:grid;
      grid-template-columns:100px 1fr;
      align-items:center;
      padding:16px 18px;
    }

    .insight-icon{
      width:72px;
      height:72px;
      border-radius:50%;
      background:linear-gradient(180deg,#ffffff 0%, #eef8f7 100%);
      border:1px solid #dfeef0;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 8px 18px rgba(11,45,92,0.10);
    }

    .insight-title{
      color:#0b2f74;
      font-size:18px;
      font-weight:900;
      text-transform:uppercase;
      margin-bottom:8px;
    }

    .insight-text{
      color:#1d2f57;
      font-size:16px;
      line-height:1.45;
    }

    .axis-label{
      fill:#0b2b6e;
      font-size:15px;
      font-weight:900;
    }

    .x-label{
      fill:#0b2b6e;
      font-size:15px;
      font-weight:900;
    }

    .value-label{
      fill:#0b2b6e;
      font-size:17px;
      font-weight:900;
    }

    .legend-text{
      fill:#0b2b6e;
      font-size:16px;
      font-weight:900;
    }

    .grid-line{
      stroke:#d8dfec;
      stroke-width:1;
      stroke-dasharray:4 4;
    }

    .baseline{
      stroke:#c8d3e2;
      stroke-width:2;
    }

    .table-note{
      font-size:12px;
      color:#6b7a98;
    }

    svg text{
      font-family:Arial, Helvetica, sans-serif;
    }
  </style>
</head>
<body>
<%
  function num(v){
    return Number(v) || 0;
  }

  function safePctText(v){
    if (v === null || v === undefined || v === '') return '0.0%';
    if (typeof v === 'string' && v.indexOf('%') !== -1) return v;
    return (Number(v) || 0).toFixed(1) + '%';
  }

  function pctNum(v){
    if (typeof v === 'string') return Number(String(v).replace('%','').trim()) || 0;
    return Number(v) || 0;
  }

  function calcPct(part, total){
    if (!total) return '0.0%';
    return ((num(part)/num(total))*100).toFixed(1) + '%';
  }

  function monthShort(v){
    return String(v || '').replace(/\./g,'').replace(/\s+/g,' ').trim();
  }

  function monthLabelFromPeriodo(periodo){
    const txt = String(periodo || '').trim();
    if (!txt) return 'Periodo';
    return txt.toUpperCase();
  }

  function iconSvg(kind){
    if(kind === 'total'){
      return `
      <svg width="44" height="44" viewBox="0 0 44 44">
        <g fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="14" cy="16" r="5"></circle>
          <circle cx="29" cy="15" r="5"></circle>
          <circle cx="22" cy="24" r="6"></circle>
          <path d="M6 32c1.5-4 5-6 8-6s6.5 2 8 6"></path>
          <path d="M21 34c1.5-5 5.5-8 10-8 2.8 0 5.3.9 7 2.7"></path>
          <path d="M13 34h18"></path>
        </g>
      </svg>`;
    }
    if(kind === 'mine'){
      return `
      <svg width="42" height="42" viewBox="0 0 42 42">
        <g fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 14h23l3 10H11z"></path>
          <path d="M14 14l2-4h10l2 4"></path>
          <circle cx="15" cy="28" r="3"></circle>
          <circle cx="28" cy="28" r="3"></circle>
        </g>
      </svg>`;
    }
    if(kind === 'surface'){
      return `
      <svg width="42" height="42" viewBox="0 0 42 42">
        <g fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 31l10-12 6 8 5-6 7 10H7z"></path>
          <path d="M14 17l4-4 2 2"></path>
        </g>
      </svg>`;
    }
    if(kind === 'pie'){
      return `
      <svg width="42" height="42" viewBox="0 0 42 42">
        <g fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="21" cy="21" r="14"></circle>
          <path d="M21 7v14h14"></path>
        </g>
      </svg>`;
    }
    if(kind === 'variation'){
      return `
      <svg width="42" height="42" viewBox="0 0 42 42">
        <g fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 8v26h24"></path>
          <path d="M11 14l7 8 6-5 7 11"></path>
          <path d="M26 28h7v-7"></path>
        </g>
      </svg>`;
    }
    if(kind === 'table'){
      return `
      <svg width="42" height="42" viewBox="0 0 42 42">
        <g fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <rect x="10" y="8" width="22" height="26" rx="2"></rect>
          <path d="M16 5v6M26 5v6M14 17h14M14 22h14M14 27h10"></path>
        </g>
      </svg>`;
    }
    if(kind === 'light'){
      return `
      <svg width="42" height="42" viewBox="0 0 42 42">
        <g fill="none" stroke="#18b4b7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 8c-5.5 0-10 4.5-10 10 0 3.5 1.8 6 4.5 8.5 1.6 1.5 2.5 3.1 2.9 4.5h4.9c.3-1.4 1.2-3 2.8-4.5 2.8-2.5 4.5-5 4.5-8.5 0-5.5-4.5-10-10-10z"></path>
          <path d="M17 34h8M18 38h6"></path>
        </g>
      </svg>`;
    }
    return '';
  }

  const safeLogo = typeof logoText !== 'undefined' ? logoText : 'COMM';
  const periodoFinal = typeof periodo !== 'undefined' ? periodo : 'Junio 2026';

  const titleFinal = typeof titulo !== 'undefined'
    ? titulo
    : `Poderosa - ${periodoFinal} - Atenciones por UP y Evolución Mensual`;

  const tipoItemsRaw = Array.isArray(tipoItems) ? tipoItems : (
    Array.isArray(meses) ? meses : []
  );

  const tipoItemsFinal = tipoItemsRaw.map(item => ({
    mes: monthShort(item.mes || item.periodo || ''),
    mina: num(item.mina || item.im || item.atencionesMina),
    superficie: num(item.superficie || item.sup || item.atencionesSuperficie),
    total: num(item.total) || num(item.mina || item.im || item.atencionesMina) + num(item.superficie || item.sup || item.atencionesSuperficie)
  })).filter(i => i.mes);

  const upItemsRaw = Array.isArray(upItems) ? upItems : [];
  const upItemsFinal = upItemsRaw.map(item => ({
    mes: monthShort(item.mes || item.periodo || ''),
    santaMaria: num(item.santaMaria || item.santa_maria || item.santa || item.sm),
    maranon: num(item.maranon || item.marañon || item.mn)
  })).filter(i => i.mes);

  const fallbackTipo = [
    { mes:'Mar-26', mina:148, superficie:205, total:353 },
    { mes:'Abr-26', mina:177, superficie:228, total:405 },
    { mes:'May-26', mina:145, superficie:248, total:393 },
    { mes:'Jun-26', mina:104, superficie:269, total:373 }
  ];

  const fallbackUp = [
    { mes:'Mar-26', santaMaria:213, maranon:140 },
    { mes:'Abr-26', santaMaria:164, maranon:241 },
    { mes:'May-26', santaMaria:212, maranon:181 },
    { mes:'Jun-26', santaMaria:233, maranon:140 }
  ];

  const tipoItemsData = tipoItemsFinal.length ? tipoItemsFinal : fallbackTipo;
  const upItemsData = upItemsFinal.length ? upItemsFinal : fallbackUp;

  const totalAtencionesFinal = num(totalAtenciones) || tipoItemsData[tipoItemsData.length-1].total;
  const totalMinaFinal = num(totalMinaGlobal) || tipoItemsData[tipoItemsData.length-1].mina;
  const totalSuperficieFinal = num(totalSuperficieGlobal) || tipoItemsData[tipoItemsData.length-1].superficie;

  const pctMinaFinal = safePctText(
    typeof participacionMina !== 'undefined' ? participacionMina : calcPct(totalMinaFinal, totalAtencionesFinal)
  );
  const pctSuperficieFinal = safePctText(
    typeof participacionSuperficie !== 'undefined' ? participacionSuperficie : calcPct(totalSuperficieFinal, totalAtencionesFinal)
  );

  const previousTotal = tipoItemsData.length >= 2 ? num(tipoItemsData[tipoItemsData.length-2].total) : 0;
  const variationComputed = previousTotal
    ? (((totalAtencionesFinal - previousTotal) / previousTotal) * 100).toFixed(1) + '%'
    : '0.0%';

  const variationFinal = typeof variacionVsPrevio !== 'undefined' && variacionVsPrevio !== null && variacionVsPrevio !== ''
    ? (String(variacionVsPrevio).indexOf('%') !== -1 ? String(variacionVsPrevio) : Number(variacionVsPrevio).toFixed(1) + '%')
    : variationComputed;

  const resumenRowsRaw = Array.isArray(resumenRows) ? resumenRows : [];
  const resumenRowsFinal = resumenRowsRaw.length ? resumenRowsRaw : [
    { up:'Santa María', mina:66, superficie:167, total:233, porcentaje:'62%' },
    { up:'Marañón', mina:38, superficie:102, total:140, porcentaje:'38%' }
  ];

  const totalResumen = {
    up:'TOTAL',
    mina: resumenRowsFinal.reduce((a,b)=>a+num(b.mina),0),
    superficie: resumenRowsFinal.reduce((a,b)=>a+num(b.superficie),0),
    total: resumenRowsFinal.reduce((a,b)=>a+num(b.total),0),
    porcentaje:'100%'
  };

  const insightFinal = typeof insight !== 'undefined' && insight
    ? insight
    : `En ${periodoFinal}, predominan las atenciones en superficie (${pctSuperficieFinal} del total), mientras que Santa María concentra la mayor participación mensual.`;

  const maxUp = Math.max(10, ...upItemsData.map(i => Math.max(i.santaMaria, i.maranon)));
  const maxTipo = Math.max(10, ...tipoItemsData.map(i => Math.max(i.mina, i.superficie)));

  const upScaleMax = Math.ceil(maxUp / 50) * 50;
  const tipoScaleMax = Math.ceil(maxTipo / 50) * 50;

  const chartH = 250;
  const baseY = 302;

  function barH(value, max){
    return max ? (num(value) / num(max)) * chartH : 0;
  }
%>

<div class="slide">
  <div class="top-curve"></div>
  <div class="bottom-band"></div>

  <div class="header">
    <div class="title-wrap">
      <div class="title-bar"></div>
      <div class="title"><%= titleFinal %></div>
    </div>
    <div class="logo">
      <div class="logo-symbol"></div>
      <div><%= safeLogo %></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-icon bg-blue"><%- iconSvg('total') %></div>
      <div>
        <div class="kpi-label">Total<br>Atenciones</div>
        <div class="kpi-value"><%= totalAtencionesFinal %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal"><%- iconSvg('mine') %></div>
      <div>
        <div class="kpi-label">Atenciones<br>Mina</div>
        <div class="kpi-value teal"><%= totalMinaFinal %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-orange"><%- iconSvg('surface') %></div>
      <div>
        <div class="kpi-label">Atenciones<br>Superficie</div>
        <div class="kpi-value orange"><%= totalSuperficieFinal %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-purple"><%- iconSvg('pie') %></div>
      <div>
        <div class="kpi-label">Participación<br>Mina</div>
        <div class="kpi-value purple"><%= pctMinaFinal %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-teal"><%- iconSvg('pie') %></div>
      <div>
        <div class="kpi-label">Participación<br>Superficie</div>
        <div class="kpi-value teal"><%= pctSuperficieFinal %></div>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon bg-blue"><%- iconSvg('variation') %></div>
      <div>
        <div class="kpi-label">Variación<br>vs Mayo</div>
        <div class="kpi-value"><%= variationFinal %></div>
      </div>
    </div>
  </div>

  <div class="main-grid">
    <!-- PANEL 1 -->
    <div class="panel">
      <div class="panel-title">Atenciones por UP – Evolución Mensual</div>
      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 760 380" preserveAspectRatio="none">
          <% [0,0.2,0.4,0.6,0.8,1].forEach(function(p){
              const y = baseY - p*chartH;
              const val = Math.round(upScaleMax*p);
          %>
            <line x1="80" y1="<%= y %>" x2="720" y2="<%= y %>" class="grid-line"></line>
            <text x="34" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
          <% }) %>

          <text x="18" y="200" transform="rotate(-90 18,200)" class="axis-label">ATENCIONES</text>

          <% 
            const leftX = 108;
            const groupGap = 155;
            const barW = 44;
            upItemsData.forEach(function(item, i){
              const groupX = leftX + i*groupGap;
              const h1 = barH(item.santaMaria, upScaleMax);
              const h2 = barH(item.maranon, upScaleMax);
              const y1 = baseY - h1;
              const y2 = baseY - h2;
          %>
            <defs>
              <linearGradient id="gupb<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#4e83ff"/>
                <stop offset="100%" stop-color="#0d44bf"/>
              </linearGradient>
              <linearGradient id="gupo<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ff9d2a"/>
                <stop offset="100%" stop-color="#ff6200"/>
              </linearGradient>
            </defs>

            <rect x="<%= groupX %>" y="<%= y1 %>" width="<%= barW %>" height="<%= h1 %>" fill="url(#gupb<%= i %>)"></rect>
            <rect x="<%= groupX + 56 %>" y="<%= y2 %>" width="<%= barW %>" height="<%= h2 %>" fill="url(#gupo<%= i %>)"></rect>

            <text x="<%= groupX + barW/2 %>" y="<%= y1 - 10 %>" text-anchor="middle" class="value-label"><%= item.santaMaria %></text>
            <text x="<%= groupX + 56 + barW/2 %>" y="<%= y2 - 10 %>" text-anchor="middle" class="value-label"><%= item.maranon %></text>

            <text x="<%= groupX + 50 %>" y="318" text-anchor="middle" class="x-label"><%= item.mes %></text>
          <% }) %>

          <rect x="238" y="342" width="13" height="13" rx="2" fill="#0d44bf"></rect>
          <text x="262" y="355" class="legend-text">U.P. Santa María</text>

          <rect x="468" y="342" width="13" height="13" rx="2" fill="#ff6200"></rect>
          <text x="492" y="355" class="legend-text">U.P. Marañón</text>

          <line x1="80" y1="<%= baseY %>" x2="720" y2="<%= baseY %>" class="baseline"></line>
        </svg>
      </div>
    </div>

    <!-- PANEL 2 -->
    <div class="panel">
      <div class="panel-title">Atenciones por Tipo (IM vs Superficie) – Evolución Mensual</div>
      <div class="chart-box">
        <svg width="100%" height="100%" viewBox="0 0 760 380" preserveAspectRatio="none">
          <% [0,0.2,0.4,0.6,0.8,1].forEach(function(p){
              const y = baseY - p*chartH;
              const val = Math.round(tipoScaleMax*p);
          %>
            <line x1="80" y1="<%= y %>" x2="720" y2="<%= y %>" class="grid-line"></line>
            <text x="34" y="<%= y + 5 %>" class="axis-label"><%= val %></text>
          <% }) %>

          <text x="18" y="200" transform="rotate(-90 18,200)" class="axis-label">ATENCIONES</text>

          <% 
            const leftX2 = 108;
            const groupGap2 = 155;
            const barW2 = 44;
            tipoItemsData.forEach(function(item, i){
              const groupX = leftX2 + i*groupGap2;
              const h1 = barH(item.mina, tipoScaleMax);
              const h2 = barH(item.superficie, tipoScaleMax);
              const y1 = baseY - h1;
              const y2 = baseY - h2;
          %>
            <defs>
              <linearGradient id="gtib<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#4e83ff"/>
                <stop offset="100%" stop-color="#0d44bf"/>
              </linearGradient>
              <linearGradient id="gtio<%= i %>" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ff9d2a"/>
                <stop offset="100%" stop-color="#ff6200"/>
              </linearGradient>
            </defs>

            <rect x="<%= groupX %>" y="<%= y1 %>" width="<%= barW2 %>" height="<%= h1 %>" fill="url(#gtib<%= i %>)"></rect>
            <rect x="<%= groupX + 56 %>" y="<%= y2 %>" width="<%= barW2 %>" height="<%= h2 %>" fill="url(#gtio<%= i %>)"></rect>

            <text x="<%= groupX + barW2/2 %>" y="<%= y1 - 10 %>" text-anchor="middle" class="value-label"><%= item.mina %></text>
            <text x="<%= groupX + 56 + barW2/2 %>" y="<%= y2 - 10 %>" text-anchor="middle" class="value-label"><%= item.superficie %></text>

            <text x="<%= groupX + 50 %>" y="318" text-anchor="middle" class="x-label"><%= item.mes %></text>
          <% }) %>

          <rect x="294" y="342" width="13" height="13" rx="2" fill="#0d44bf"></rect>
          <text x="318" y="355" class="legend-text">IM</text>

          <rect x="390" y="342" width="13" height="13" rx="2" fill="#ff6200"></rect>
          <text x="414" y="355" class="legend-text">SUPERFICIE</text>

          <line x1="80" y1="<%= baseY %>" x2="720" y2="<%= baseY %>" class="baseline"></line>
        </svg>
      </div>
    </div>
  </div>

  <div class="bottom-grid">
    <div class="summary-card">
      <div class="summary-side">
        <div class="summary-icon"><%- iconSvg('table') %></div>
      </div>

      <div class="summary-main">
        <div class="summary-title">Resumen <%= monthLabelFromPeriodo(periodoFinal) %></div>

        <table>
          <thead>
            <tr>
              <th rowspan="2" style="width:18%;">UP</th>
              <th colspan="2" style="width:40%;">ATENCIONES</th>
              <th rowspan="2" style="width:16%;">TOTAL</th>
              <th rowspan="2" style="width:16%;">%</th>
            </tr>
            <tr>
              <th>MINA</th>
              <th>SUPERFICIE</th>
            </tr>
          </thead>
          <tbody>
            <% resumenRowsFinal.forEach(function(row){ %>
              <tr>
                <td><%= row.up %></td>
                <td><%= row.mina %></td>
                <td><%= row.superficie %></td>
                <td><%= row.total %></td>
                <td><%= row.porcentaje || row.pct || calcPct(row.total, totalResumen.total) %></td>
              </tr>
            <% }) %>
            <tr class="total-row">
              <td><%= totalResumen.up %></td>
              <td><%= totalResumen.mina %></td>
              <td><%= totalResumen.superficie %></td>
              <td><%= totalResumen.total %></td>
              <td><%= totalResumen.porcentaje %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="insight-box">
      <div class="insight-icon"><%- iconSvg('light') %></div>
      <div>
        <div class="insight-title">Insight Principal</div>
        <div class="insight-text"><%= insightFinal %></div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
